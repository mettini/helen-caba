{
  "_comment": "Config del scraper. Editá y re-corré `python3 scripts/scrape.py`. Ver README.md § 'Tocar la config'.",

  "sources": {
    "argenprop": {
      "habilitado": true,
      "base_url": "https://www.argenprop.com/ph/alquiler/{slug}",
      "max_pages_per_barrio": 10,
      "pagina_param": "pagina"
    },
    "remax": {
      "habilitado": true,
      "api_url": "https://api-ar.redremax.com/remaxweb-ar/api/listings/findAllWithEntrepreneurships",
      "listing_url_prefix": "https://www.remax.com.ar/listings/",
      "operation_id": 2,
      "type_id": 12,
      "page_size": 50,
      "image_cdn": "https://d1acdg20u0pmxj.cloudfront.net/",
      "image_size_suffix": "360x200",
      "image_ext": ".webp"
    },
    "airbnb": {
      "habilitado": true,
      "_comment": "Airbnb no categoriza por 'PH' (PH es un término argentino). Todos los listings de Airbnb se etiquetan tipo='Depto' (mayoría) o 'Casa' si aplica. El UI tiene un filtro 'Tipo de propiedad' con 'PH' seleccionado por default — los de Airbnb aparecen solo al destildar."
    },
    "mercadolibre": {
      "habilitado": true,
      "max_pages": 6,
      "_comment": "Scrapea UI web (la API oficial tira 403). Dos pasadas: alquiler tradicional + alquiler-temporario. Los slugs de barrios del config se usan directo en la URL (barrio-o-barrio-o-...)."
    },
    "zonaprop": {
      "habilitado": true,
      "max_pages": 10,
      "barrios_per_url": 8,
      "_comment": "Requiere curl_cffi (pip3 install --break-system-packages curl_cffi) para pasar Cloudflare. Extrae window.__PRELOADED_STATE__ — JSON limpio. Chunkea barrios en la URL (por límite de longitud)."
    },
    "properati": {
      "habilitado": false,
      "max_pages": 3,
      "_comment": "DESHABILITADO: Properati no categoriza PH separado de Departamento (todo lumped como 'Departamento en Alquiler en X'). Verificado abril 2026: 0/60 listings tienen 'PH' en título o markup. Lo dejamos por si en el futuro agregan el filtro. Si se habilita, scraper pide /s/{barrio}/alquiler y filtra client-side."
    }
  },

